// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  recipes   Recipe[]
  favorites FavoriteRecipe[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recipe {
  id            String    @id @default(uuid())  // UUID primary key
  recipeSlug    String    @unique               // Unique slug for URL-friendly identifiers
  imageKey      String?                         // Optional image key for AWS S3 storage
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  title         String
  description   String
  baseServings  Int      @default(2)
  ingredients   RecipeIngredient[]
  instructions  String[]
  variants      RecipeVariant[]
  favoritedBy   FavoriteRecipe[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//This is your nutrition source of truth.
model Ingredient {
  id            String   @id @default(uuid())
  ingredientId        String
  name                String
  caloriesPer100g     Float
  proteinPer100g      Float
  fatPer100g          Float
  carbohydratesPer100g Float
  nativeCountry           Country? @relation(fields: [nativeCountryId], references: [id])
  nativeCountryId         String?

  recipeLinks             RecipeIngredient[]
  recipeVariantLinks      RecipeVariantIngredient[]
  
  substitutionsFrom       IngredientSubstitution[] @relation("SubstitutionFrom")
  substitutionsTo         IngredientSubstitution[] @relation("SubstitutionTo")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model IngredientSubstitution {
  id               String     @id @default(uuid())

  fromIngredient   Ingredient @relation("SubstitutionFrom", fields: [fromIngredientId], references: [id])
  fromIngredientId String

  toIngredient     Ingredient @relation("SubstitutionTo", fields: [toIngredientId], references: [id])
  toIngredientId   String

  country          Country?   @relation(fields: [countryId], references: [id])
  countryId        String?

  ratio            Float      @default(1)
  notes            String?
  confidence       Float?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([fromIngredientId, toIngredientId, countryId])
}

//This means that this recipe uses this ingredient in this amount
model RecipeIngredient {
   id           String     @id @default(uuid())

  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  recipeId     String

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String

  quantity     Float
  unit         UnitType
  note         String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model RecipeVariant {
  id            String    @id @default(uuid())

  baseRecipe    Recipe    @relation(fields: [baseRecipeId], references: [id])
  baseRecipeId  String

  country       Country   @relation(fields: [countryId], references: [id])
  countryId     String

  title         String
  description   String?
  ingredients   RecipeVariantIngredient[]
  instructions  String[]

  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([baseRecipeId, countryId])
}

model RecipeVariantIngredient {
  id              String        @id @default(uuid())

  recipeVariant   RecipeVariant @relation(fields: [recipeVariantId], references: [id])
  recipeVariantId String

  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  ingredientId    String

  quantity        Float
  unit            UnitType
  note            String?
}

enum UnitType {
  G
  KG
  ML
  L
  PIECE
  CUP
  TBSP
  TSP
  DL
}

model FavoriteRecipe {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  recipeId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  id        String   @id @default(uuid())
  name      String
  code      String
  ingredients Ingredient[]
  recipeVariants RecipeVariant[]
  ingredientSubstitutions IngredientSubstitution[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}